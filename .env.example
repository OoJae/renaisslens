# ─── RenaissLens ──────────────────────────────────────────────
# Every variable below is OPTIONAL. `pnpm i && pnpm dev` runs the
# full dashboard offline from committed snapshots with NO env vars.
#
# NOTE: no .env loader is bundled — export these in your shell (or
# your process manager) rather than relying on a .env file.

# AI explainer. The endpoint speaks the Anthropic API protocol — point it at
# Anthropic (default) or any compatible provider (e.g. Xiaomi MiMo). When this
# key is unset, POST /api/explain returns HTTP 503 with a friendly error and
# the pack pages hide the explain button entirely. Never required.
ANTHROPIC_API_KEY=

# Explainer model. Default: claude-opus-4-8. Optional.
# For MiMo, set: mimo-v2.5-pro
RENAISSLENS_EXPLAINER_MODEL=

# Explainer endpoint base URL (Anthropic-protocol compatible). Default: Anthropic. Optional.
# For MiMo, set: https://token-plan-sgp.xiaomimimo.com/anthropic
RENAISSLENS_EXPLAINER_BASE_URL=

# Base URLs for live ingestion (pnpm scrape). Defaults shown.
RENAISS_API_URL=https://api.renaiss.xyz
RENAISS_SITE_URL=https://www.renaiss.xyz

# Renaiss OS Index API — independent reference prices, cross-checked against FMV.
# INTEGRATED but optional: with a partner key+secret set, the `api-index` source
# (daily) fetches the index panel and exact-matches marketplace listings. When
# unset, the source self-skips with no network call and the market page simply
# omits the Index cross-reference. Sent as X-Api-Key / X-Api-Secret headers.
# Never required.
RENAISS_INDEX_API_URL=https://api.renaissos.com
RENAISS_INDEX_API_KEY=
RENAISS_INDEX_API_SECRET=

# Override sqlite file location. Default: <repo>/data/renaisslens.db
# Relative paths resolve against the repo root.
RENAISSLENS_DB_PATH=

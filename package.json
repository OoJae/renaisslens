{
  "name": "renaisslens",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=26.0.0 <27"
  },
  "scripts": {
    "dev": "pnpm db:migrate && pnpm scrape:mock && pnpm --filter @renaisslens/web dev",
    "build": "pnpm db:migrate && pnpm scrape:mock && pnpm --filter @renaisslens/web build",
    "start": "pnpm --filter @renaisslens/web start",
    "scrape": "pnpm --filter @renaisslens/scraper scrape",
    "scrape:mock": "pnpm --filter @renaisslens/scraper scrape:mock",
    "scrape:watch": "pnpm --filter @renaisslens/scraper scrape:watch",
    "codegen:api": "pnpm --filter @renaisslens/scraper codegen",
    "snapshots:prune": "pnpm --filter @renaisslens/scraper prune",
    "db:migrate": "pnpm --filter @renaisslens/db migrate",
    "db:reset": "pnpm --filter @renaisslens/db reset && pnpm scrape:mock",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  }
}
